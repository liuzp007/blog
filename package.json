{
  "name": "appa",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons": "^4.7.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@reduxjs/toolkit": "^2.11.2",
    "animejs": "^3.2.2",
    "antd": "^4.24.16",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "postprocessing": "^6.39.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "react-router-dom": "^5.3.4",
    "redux-persist": "^6.0.0",
    "three": "0.182.0"
  },
  "scripts": {
    "predev": "node scripts/generate-content-meta.mjs",
    "prestart": "node scripts/generate-content-meta.mjs",
    "prebuild": "node scripts/generate-content-meta.mjs",
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "audit:style": "node scripts/audit-style.js",
    "audit:styles": "node scripts/audit-style.js",
    "build:content-meta": "node scripts/generate-content-meta.mjs",
    "build:seo": "node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs",
    "build:search": "node scripts/generate-search-index.mjs",
    "check:content": "node scripts/check-content.mjs",
    "preview": "vite preview --host",
    "type-check": "tsc --noEmit",
    "analyze": "vite build --mode analyze",
    "lint": "pnpm lint:baseline",
    "lint:baseline": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "pnpm format:write:baseline",
    "format:write:baseline": "prettier --write \"src/**/*.{ts,tsx,scss,css}\" \"package.json\" \".eslintrc.json\" \".prettierrc\"",
    "format:check": "pnpm format:check:baseline",
    "format:check:baseline": "prettier --check \"src/**/*.{ts,tsx,scss,css}\" \"package.json\" \".eslintrc.json\" \".prettierrc\"",
    "lint:style": "stylelint \"src/**/*.scss\" \"src/**/*.css\"",
    "ci:check": "pnpm type-check && pnpm lint && pnpm format:check && pnpm lint:style && pnpm audit:style && pnpm build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@types/react-router-dom": "^5.3.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "consola": "^3.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "history": "^5.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "storybook": "^10.3.5",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-style-import": "^2.0.0",
    "vitest": "^4.1.4"
  },
  "homepage": "./",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{scss,css,json}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ]
  }
}
